<core:CustomWindow x:Class="IDESK.Console.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:IDESK.Core;assembly=IDESK.Core"
        Title="iDesk Console" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemePageBackground}">
    <core:CustomWindow.Resources>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 4 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <Path x:Name="icon" Data="{DynamicResource IconClose}"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Fill="{DynamicResource TextPrimaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource CloseButtonHoverBg}"/>
                                <Setter TargetName="icon" Property="Fill" Value="{DynamicResource CloseButtonHoverFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </core:CustomWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部 Logo 栏 -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnTitleBarMouseDown">
            <TextBlock Text="IDESK" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="14 0 0 0"/>
            <Button x:Name="CloseBtn" Style="{DynamicResource CloseButtonStyle}"
                    Click="OnCloseClick"/>
        </Grid>

        <!-- 内容区域 -->
        <Grid Grid.Row="1" Margin="20 0 20 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态栏 -->
            <Border Grid.Column="0" Margin="0 0 -16 0" CornerRadius="4">
                <StackPanel VerticalAlignment="Bottom">
                    <Button Width="24" Height="24" HorizontalAlignment="Center"
                            Style="{DynamicResource FadedButtonStyle}" ToolTip="主题切换" Click="OnThemeClick">
                        <Path Data="{DynamicResource IconPaint}" Stretch="Uniform"
                              Fill="{DynamicResource StatusIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <Button Width="24" Height="24" HorizontalAlignment="Center" Margin="0 8 0 0"
                            Style="{DynamicResource FadedButtonStyle}" ToolTip="帮助" Click="OnHelpClick">
                        <Path Data="{DynamicResource IconHelp}" Stretch="Uniform"
                              Fill="{DynamicResource StatusIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <Button Width="24" Height="24" HorizontalAlignment="Center" Margin="0 8 0 0"
                            Style="{DynamicResource FadedButtonStyle}" ToolTip="版本记录" Click="OnVersionClick">
                        <Path Data="{DynamicResource IconHistory}" Stretch="Uniform"
                              Fill="{DynamicResource StatusIconBrush}" Width="18" Height="18"/>
                    </Button>
                    <Button Width="24" Height="24" HorizontalAlignment="Center" Margin="0 8 0 0"
                            Style="{DynamicResource FadedButtonStyle}" ToolTip="退出程序" Click="OnExitClick">
                        <Path Data="{DynamicResource IconShutdown}" Stretch="Uniform"
                              Fill="{DynamicResource DangerBrush}" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 导航栏 -->
            <Border Grid.Column="1" CornerRadius="4" Margin="0 0 10 180">
                <ListBox x:Name="NavList" BorderThickness="0" Background="Transparent"
                         SelectedIndex="0" SelectionChanged="OnNavSelectionChanged"
                         ItemContainerStyle="{DynamicResource NavItemStyle}">
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconChat}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="AI 助手" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconNotes}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="笔记" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconTodo}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="待办" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconSchedule}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="日程" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconTranslate}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="翻译" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconHabit}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="习惯" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconPlan}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="计划" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconToolbox}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="小组件" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="DebugNavItem">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconTest}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="调试" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{DynamicResource IconSettings}" Stretch="Uniform"
                                  Fill="{DynamicResource NavIconBrush}" Width="18" Height="18"/>
                            <Label Content="设置" FontSize="13" Padding="8 0 0 0"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <ContentControl x:Name="ContentArea" Grid.Column="2"/>
        </Grid>
    </Grid>
</core:CustomWindow>
