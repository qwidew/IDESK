<UserControl x:Class="IDESK.Console.Control.PlanPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
        </ScrollViewer.Resources>
        <StackPanel>
            <!-- 计划组件 -->
            <Grid VerticalAlignment="Top" Margin="4">
                <Border x:Name="PlanCreateBtn" Height="120" CornerRadius="6" Margin="4"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonDown="OnPlanCreateClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Path Grid.Row="0" Data="{DynamicResource IconAdd}" Stretch="Uniform"
                              Fill="{DynamicResource ActionIconBrush}" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <Label Grid.Row="1" Content="添加计划组件" FontSize="12"
                               HorizontalAlignment="Center" Padding="4" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <Border x:Name="PlanCard" Height="120" CornerRadius="6" Margin="4"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Background="{DynamicResource SectionBgBrush}" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Data="{DynamicResource IconPlan}" Stretch="Uniform"
                                  Fill="{DynamicResource ActionIconBrush}" Width="28" Height="28" HorizontalAlignment="Center"/>
                            <Label Content="计划组件" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Padding="4" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1" Width="60" Height="24" Margin="0 0 0 8"
                                HorizontalAlignment="Center"
                                Style="{DynamicResource DangerButtonStyle}" Click="OnPlanDeleteClick">
                            <Label Content="删除" FontSize="11"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- 计划 Lite 组件 -->
            <Grid VerticalAlignment="Top" Margin="4">
                <Border x:Name="LiteCreateBtn" Height="120" CornerRadius="6" Margin="4"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonDown="OnLiteCreateClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Path Grid.Row="0" Data="{DynamicResource IconAdd}" Stretch="Uniform"
                              Fill="{DynamicResource ActionIconBrush}" Width="24" Height="24" HorizontalAlignment="Center"/>
                        <Label Grid.Row="1" Content="添加计划 Lite" FontSize="12"
                               HorizontalAlignment="Center" Padding="4" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <Border x:Name="LiteCard" Height="120" CornerRadius="6" Margin="4"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Background="{DynamicResource SectionBgBrush}" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Data="{DynamicResource IconPlan}" Stretch="Uniform"
                                  Fill="{DynamicResource ActionIconBrush}" Width="28" Height="28" HorizontalAlignment="Center"/>
                            <Label Content="计划 Lite" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Padding="4" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1" Width="60" Height="24" Margin="0 0 0 8"
                                HorizontalAlignment="Center"
                                Style="{DynamicResource DangerButtonStyle}" Click="OnLiteDeleteClick">
                            <Label Content="删除" FontSize="11"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
