<UserControl x:Class="IDESK.Console.Control.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="44" Height="22" CornerRadius="11"
                                Background="#555" Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.2"/>
                            </Border.Effect>
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="2 0 0 0"
                                     VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation To="#4CAF50" Duration="0:0:0.15"
                                                Storyboard.TargetName="Track"
                                                Storyboard.TargetProperty="Background.Color"/>
                                            <ThicknessAnimation To="24 0 0 0" Duration="0:0:0.15"
                                                Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation To="#555" Duration="0:0:0.15"
                                                Storyboard.TargetName="Track"
                                                Storyboard.TargetProperty="Background.Color"/>
                                            <ThicknessAnimation To="2 0 0 0" Duration="0:0:0.15"
                                                Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProviderSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="170"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Width="170" Height="30" CornerRadius="6"
                                Background="#555" Cursor="Hand">
                            <Grid>
                                <TextBlock Text="OpenAI" FontSize="12"
                                           Foreground="#999" VerticalAlignment="Center"
                                           HorizontalAlignment="Left" Margin="22 0 0 0"/>
                                <TextBlock Text="Anthropic" FontSize="12"
                                           Foreground="#999" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0 0 22 0"/>
                                <Border x:Name="Thumb" Width="80" Height="26" CornerRadius="5"
                                        Background="White" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="3"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3"/>
                                    </Border.Effect>
                                    <Grid>
                                        <TextBlock x:Name="TbOpenAi" Text="OpenAI" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#333"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TbAnthropic" Text="Anthropic" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#333"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation To="87" Duration="0:0:0.15"
                                                Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"/>
                                            <ObjectAnimationUsingKeyFrames Duration="0"
                                                Storyboard.TargetName="TbOpenAi"
                                                Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Duration="0"
                                                Storyboard.TargetName="TbAnthropic"
                                                Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation To="3" Duration="0:0:0.15"
                                                Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)"/>
                                            <ObjectAnimationUsingKeyFrames Duration="0"
                                                Storyboard.TargetName="TbOpenAi"
                                                Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Duration="0"
                                                Storyboard.TargetName="TbAnthropic"
                                                Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="30 20">
        <ScrollViewer>
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <StackPanel>
            <!-- 设置 标题 -->
            <Label Content="设置" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 0 0 25"/>

            <!-- 基础设置 大区块 -->
            <Label Content="基础设置" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 10 0"/>

            <Border CornerRadius="6" Background="{DynamicResource SectionBgBrush}" Padding="0">
                <StackPanel>
                    <!-- 数据文件夹 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="数据文件夹" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <Button Width="150" Height="30" HorizontalAlignment="Right"
                                Style="{DynamicResource DefaultButtonStyle}" Click="OnOpenDataFolder">
                            <Label Content="打开 AppData 目录" FontSize="12"/>
                        </Button>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- 开机自启 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="开机自启" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="70" Height="30" Margin="0 0 8 0"
                                    Style="{DynamicResource DefaultButtonStyle}" Click="OnEnableAutoStart">
                                <Label Content="开启" FontSize="12"/>
                            </Button>
                            <Button Width="70" Height="30"
                                    Style="{DynamicResource DangerButtonStyle}" Click="OnDisableAutoStart">
                                <Label Content="关闭" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- 启动时不打开控制台 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="启动时不打开控制台" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <ToggleButton x:Name="StartMinimizedToggle"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      HorizontalAlignment="Right"
                                      Checked="OnStartMinimizedToggle" Unchecked="OnStartMinimizedToggle"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- 按键绑定 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="按键绑定" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <Button Width="110" Height="30" HorizontalAlignment="Right"
                                Style="{DynamicResource DefaultButtonStyle}" Click="OnOpenKeyBindings">
                            <Label Content="配置快捷键" FontSize="12"/>
                        </Button>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- 卸载 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="卸载" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <Button Width="110" Height="30" HorizontalAlignment="Right"
                                Style="{DynamicResource DefaultButtonStyle}" Click="OnUninstallInfo">
                            <Label Content="查看卸载信息" FontSize="12"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- LLM 设置 -->
            <Label Content="LLM 设置" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 20 0 10"/>

            <Border CornerRadius="6" Background="{DynamicResource SectionBgBrush}" Padding="0">
                <StackPanel>
                    <!-- 提供商切换 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="API 格式" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <ToggleButton x:Name="ProviderToggle"
                                      Style="{StaticResource ProviderSwitchStyle}"
                                      HorizontalAlignment="Right"
                                      Checked="OnProviderToggle" Unchecked="OnProviderToggle"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- API URL -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="请求地址" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <TextBox x:Name="ApiUrlBox" Width="200" Height="30" FontSize="12"
                                 HorizontalAlignment="Right" VerticalContentAlignment="Center"
                                 Padding="8 0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- API Key -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="请求密钥" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <PasswordBox x:Name="ApiKeyBox" Width="200" Height="30" FontSize="12"
                                     HorizontalAlignment="Right" VerticalContentAlignment="Center"
                                     Padding="8 0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- Model -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="模型" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <TextBox x:Name="ModelBox" Width="200" Height="30" FontSize="12"
                                 HorizontalAlignment="Right" VerticalContentAlignment="Center"
                                 Padding="8 0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- MaxContext -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="上下文长度" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <TextBox x:Name="MaxContextBox" Width="200" Height="30" FontSize="12"
                                 HorizontalAlignment="Right" VerticalContentAlignment="Center"
                                 Padding="8 0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- MaxLoops -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="最大循环" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <TextBox x:Name="MaxLoopsBox" Width="200" Height="30" FontSize="12"
                                 HorizontalAlignment="Right" VerticalContentAlignment="Center"
                                 Padding="8 0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="16 0"/>

                    <!-- 保存按钮 -->
                    <Grid Margin="16 12 16 12">
                        <Button Width="80" Height="30" HorizontalAlignment="Right"
                                Style="{DynamicResource DefaultButtonStyle}" Click="OnSaveLlmConfig">
                            <Label Content="保存" FontSize="12"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
            <!-- 其他设置 -->
            <Label Content="其他设置" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 20 0 10"/>

            <Border CornerRadius="6" Background="{DynamicResource SectionBgBrush}" Padding="0">
                <StackPanel>
                    <!-- 临时窗口失焦自动关闭 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="临时窗口失焦自动关闭" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <ToggleButton x:Name="AutoCloseToggle"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      HorizontalAlignment="Right"
                                      Checked="OnAutoCloseToggle" Unchecked="OnAutoCloseToggle"/>
                    </Grid>

                    <!-- 危险操作确认 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="危险操作确认" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <ToggleButton x:Name="DangerConfirmToggle"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      HorizontalAlignment="Right"
                                      Checked="OnDangerConfirmToggle" Unchecked="OnDangerConfirmToggle"/>
                    </Grid>

                    <!-- 调试页面 -->
                    <Grid Margin="16 12 16 12">
                        <Label Content="调试页面" FontSize="13" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                        <ToggleButton x:Name="DebugPageToggle"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      HorizontalAlignment="Right"
                                      Checked="OnDebugPageToggle" Unchecked="OnDebugPageToggle"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
