<UserControl x:Class="IDESK.Console.Control.TodoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:IDESK.Console.Control"
             xmlns:helper="clr-namespace:IDESK.Core.Helper;assembly=IDESK.Core">
    <UserControl.Resources>
        <helper:HalfConverter x:Key="HalfConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button x:Name="CreateBtn" Grid.Row="0" Width="120" Height="36" Margin="10"
                Style="{DynamicResource DefaultButtonStyle}"
                Click="OnCreateClick">
            <StackPanel Orientation="Horizontal">
                <Path Data="{DynamicResource IconAdd}" Stretch="Uniform"
                      Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14"/>
                <Label Content="创建实例" FontSize="12" Padding="4 0"/>
            </StackPanel>
        </Button>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <ItemsControl x:Name="InstanceList"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                       ItemWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportWidth, Converter={StaticResource HalfConverter}, FallbackValue=400}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="VerticalAlignment" Value="Top"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:TodoInstanceBlock Margin="4"
                            DeleteCommand="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.DeleteCommand}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 弹出层 -->
        <Grid x:Name="Overlay" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Width="320" Height="160"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Direction="270" BlurRadius="12" ShadowDepth="6" Opacity="0.3"/>
                </Border.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="新建实例" FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0 0 0 10"/>

                    <TextBox Grid.Row="1" x:Name="InstanceNameBox"
                             Style="{DynamicResource DefaultTextBoxStyle}"
                             VerticalAlignment="Top" Height="30"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0 10 0 0">
                        <Button Width="70" Height="28" Margin="0 0 10 0"
                                Style="{DynamicResource DefaultButtonStyle}"
                                Click="OnConfirmClick">
                            <Label Content="确定" FontSize="11"/>
                        </Button>
                        <Button Width="70" Height="28"
                                Style="{DynamicResource BorderlessButtonStyle}"
                                Click="OnCancelClick">
                            <Label Content="取消" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
