<UserControl x:Class="IDESK.Console.Control.KeyBindingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="30 20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 右上角关闭 -->
        <Button Width="28" Height="28" HorizontalAlignment="Right"
                Style="{DynamicResource BorderlessButtonStyle}" Click="OnBackClick">
            <Path Data="{DynamicResource IconClose}" Fill="{DynamicResource ActionIconBrush}"
                  Width="16" Height="16" Stretch="Uniform"/>
        </Button>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <StackPanel>
            <!-- 标题 -->
            <Label Content="按键绑定" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0 0 0 20"/>

            <!-- 表头 -->
            <Grid Margin="0 0 0 6">
                <Label Content="动作" FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                <Label x:Name="ActionHeader" Content="快捷键" FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            </Grid>
            <Border Height="1" Background="{DynamicResource SeparatorBrush}"/>

            <!-- 打开 Console -->
            <Grid Margin="0 12 0 0" Tag="OpenConsole">
                <Label Content="打开 Console" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="ConsoleKeyText" Content="Alt + W" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="OpenConsole"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="OpenConsole"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="ConsoleRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 显示/隐藏组件 -->
            <Grid Margin="0 0 0 0" Tag="ToggleWidgets">
                <Label Content="显示/隐藏组件" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="ToggleKeyText" Content="Alt + S" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="ToggleWidgets"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="ToggleWidgets"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="ToggleRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 打开 Chat -->
            <Grid Margin="0 0 0 0" Tag="ToggleChat">
                <Label Content="打开 Chat" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="ChatKeyText" Content="Alt + Space" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="ToggleChat"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="ToggleChat"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="ChatRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 打开 Translate -->
            <Grid Margin="0 0 0 0" Tag="ToggleTranslate">
                <Label Content="打开 Translate" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="TranslateKeyText" Content="Alt + C" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="ToggleTranslate"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="ToggleTranslate"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="TranslateRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 截图 → Chat -->
            <Grid Margin="0 0 0 0" Tag="Screenshot">
                <Label Content="截图识别 → Chat" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="ScreenshotKeyText" Content="Alt + Shift + S" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="Screenshot"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="Screenshot"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="ScreenshotRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 截图 → Translate -->
            <Grid Margin="0 0 0 0" Tag="ScreenshotTranslate">
                <Label Content="截图识别 → Translate" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="ScreenshotTranslateKeyText" Content="Alt + Shift + C" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="ScreenshotTranslate"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="ScreenshotTranslate"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="ScreenshotTranslateRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 最小化到书签 -->
            <Grid Margin="0 0 0 0" Tag="Minimize">
                <Label Content="全部最小化到书签" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="MinimizeKeyText" Content="Alt + V" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="Minimize"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="Minimize"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="MinimizeRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 组件置顶 -->
            <Grid Margin="0 0 0 0" Tag="Topmost">
                <Label Content="组件置顶闪现" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="TopmostKeyText" Content="Alt + X" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="Topmost"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="Topmost"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="TopmostRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0 10"/>

            <!-- 调试窗口 -->
            <Grid Margin="0 0 0 0" Tag="Debug">
                <Label Content="调试窗口" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}"
                            Padding="10 4" Margin="0 0 10 0" MinWidth="100">
                        <Label x:Name="DebugKeyText" Content="Alt + F3" FontSize="12"
                               HorizontalAlignment="Center" Padding="0"/>
                    </Border>
                    <Button Width="30" Height="30" Margin="0 0 6 0" Tag="Debug"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnResetClick"
                            ToolTip="恢复默认">
                        <Path Data="{DynamicResource IconRefresh}" Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                    <Button Width="30" Height="30" Tag="Debug"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnRecordClick"
                            ToolTip="修改">
                        <Path x:Name="DebugRecordIcon" Data="{DynamicResource IconEdit}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Label x:Name="HintText" Content="" FontSize="12"
                   Foreground="{DynamicResource AccentBrush}" Margin="0 12 0 0"/>
            <Label Content="提示：" FontSize="10" FontWeight="SemiBold"
                   Foreground="#888" Margin="0 8 0 2"/>
            <Label Content="1. 需要添加 Alt 修饰键时，请点击右下角的 Alt 按钮" FontSize="10"
                   Foreground="#888" Padding="0 0 0 1"/>
            <Label Content="2. 修改后需要重启程序才能生效" FontSize="10"
                   Foreground="#888" Padding="0 0 0 1"/>
            <Label Content="3. 如果修改后快捷键无效，可能是已被其他程序占用" FontSize="10"
                   Foreground="#888" Padding="0 0 0 1"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 右下角 Alt 按钮（录制时显示） -->
        <Button x:Name="AltBtn" Width="80" Height="28"
                Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Style="{DynamicResource DefaultButtonStyle}" Click="OnAltClick"
                Visibility="Collapsed" IsEnabled="False">
            <Label x:Name="AltBtnLabel" Content="Alt" FontSize="12"/>
        </Button>
    </Grid>
</UserControl>
