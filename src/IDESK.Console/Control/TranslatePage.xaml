<UserControl x:Class="IDESK.Console.Control.TranslatePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helper="clr-namespace:IDESK.Core.Helper;assembly=IDESK.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 切换按钮 -->
        <Button x:Name="ToggleBtn" Grid.Row="0" Width="130" Height="36" Margin="10"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Style="{DynamicResource DefaultButtonStyle}" Click="OnToggleClick">
            <StackPanel Orientation="Horizontal">
                <Path x:Name="ToggleIcon" Data="{DynamicResource IconAdd}" Stretch="Uniform"
                      Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14"/>
                <Label x:Name="ToggleLabel" Content="添加小组件" FontSize="12" Padding="4 0"/>
            </StackPanel>
        </Button>

        <!-- 翻译结果 -->
        <ScrollViewer Grid.Row="1" Padding="20 15"
                      helper:ScrollViewerHelper.AutoHideScrollBars="True">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <Grid>
                <StackPanel x:Name="ResultPanel"/>
            </Grid>
        </ScrollViewer>

        <!-- 输入区域 -->
        <Border Grid.Row="2" Padding="15 10" Background="Transparent"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0 1 0 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="DirectionBtn" Width="52" Height="26" Content="英译中"
                        FontSize="11" Cursor="Hand"
                        Style="{DynamicResource FadedButtonStyle}"
                        Click="OnDirectionToggle" Margin="0,0,6,0"/>
                <TextBox x:Name="InputBox" Grid.Column="1" Height="34" VerticalContentAlignment="Center"
                         Padding="10 0" FontSize="13"
                         Style="{DynamicResource DefaultTextBoxStyle}"
                         AcceptsReturn="True"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         PreviewKeyDown="OnInputPreviewKeyDown"/>
                <Button x:Name="MicBtn" Grid.Column="2" Width="32" Height="32" Margin="0 0 6 0"
                        Style="{DynamicResource FadedButtonStyle}" Click="OnMicClick"
                        ToolTip="语音输入">
                    <Path x:Name="MicIcon" Data="{DynamicResource IconMic}" Stretch="Uniform"
                          Fill="{DynamicResource ActionIconBrush}" Width="16" Height="16"/>
                </Button>
                <Button x:Name="SendBtn" Grid.Column="3" Width="70" Height="34"
                        Style="{DynamicResource DefaultButtonStyle}" Click="OnSendClick">
                    <Label x:Name="SendBtnLabel" Content="翻译" FontSize="13"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
