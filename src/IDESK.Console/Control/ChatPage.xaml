<UserControl x:Class="IDESK.Console.Control.ChatPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helper="clr-namespace:IDESK.Core.Helper;assembly=IDESK.Core">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧主题胶囊 -->
        <Grid Grid.Column="0">
            <Border x:Name="CapsuleBody" CornerRadius="22" Padding="5 12"
                    VerticalAlignment="Center" MaxHeight="420">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TopicPanel" HorizontalAlignment="Center"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 右侧聊天区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 主题名称 + 设置按钮 -->
            <Grid Grid.Row="0" Height="38">
                <Label x:Name="TopicTitle" Content="" FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Padding="0"
                       VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       PreviewMouseDown="OnTopicTitleClick"/>
                <TextBox x:Name="TopicTitleBox" Visibility="Collapsed"
                         FontSize="15" FontWeight="SemiBold"
                         BorderThickness="0" Background="Transparent"
                         HorizontalAlignment="Center"
                         VerticalContentAlignment="Center"
                         TextAlignment="Center"
                         Padding="0"
                         LostFocus="OnTopicTitleEndEdit"
                         KeyDown="OnTopicTitleKeyDown"/>
                <Button x:Name="TopicSettingsBtn" Width="24" Height="24"
                        HorizontalAlignment="Right" Margin="0 0 8 0"
                        Style="{DynamicResource BorderlessButtonStyle}"
                        Click="OnTopicSettingsClick" Cursor="Hand">
                    <Path Data="{DynamicResource IconSettings}"
                          Width="14" Height="14" Stretch="Uniform"
                          Fill="{DynamicResource ActionIconBrush}"/>
                </Button>

                <!-- 主题设置菜单 -->
                <Popup x:Name="TopicSettingsPopup" Placement="Bottom"
                       StaysOpen="False" AllowsTransparency="True">
                    <Border CornerRadius="6" Padding="4"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel MinWidth="140">
                            <Border x:Name="SetDefaultItem" Padding="8 6" Cursor="Hand"
                                    CornerRadius="4" Background="Transparent"
                                    MouseDown="OnSetDefaultTopic">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DefaultCheckMark" Grid.Column="0"
                                               Text="✓" FontSize="13" FontWeight="Bold"
                                               Visibility="Collapsed" Margin="0 0 6 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="设为默认主题" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Margin="6 4" Background="{DynamicResource SeparatorBrush}"/>
                            <Border x:Name="LiteChatItem" Padding="8 6" Cursor="Hand"
                                    CornerRadius="4" Background="Transparent"
                                    MouseDown="OnToggleLiteChat">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LiteChatCheck" Text="✓" FontSize="13"
                                               FontWeight="Bold" Visibility="Collapsed"
                                               Margin="0 0 6 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Lite Chat" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                            </Border>
                            <Border x:Name="TempChatItem" Padding="8 6" Cursor="Hand"
                                    CornerRadius="4" Background="Transparent"
                                    MouseDown="OnToggleTempChat">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TempChatCheck" Text="✓" FontSize="13"
                                               FontWeight="Bold" Visibility="Collapsed"
                                               Margin="0 0 6 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Temp Chat" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                            </Border>
                            <Border x:Name="NoHistoryItem" Padding="8 6" Cursor="Hand"
                                    CornerRadius="4" Background="Transparent"
                                    MouseDown="OnToggleNoHistory">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="NoHistoryCheck" Text="✓" FontSize="13"
                                               FontWeight="Bold" Visibility="Collapsed"
                                               Margin="0 0 6 0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="No History" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Popup>

                <Border Height="1" VerticalAlignment="Bottom"
                        Background="{DynamicResource SeparatorBrush}"/>
            </Grid>

            <!-- 消息列表 -->
            <ScrollViewer x:Name="MessageScroll" Grid.Row="1" Padding="20 15"
                          helper:ScrollViewerHelper.AutoHideScrollBars="True">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <Grid>
                    <StackPanel x:Name="MessagePanel">
                        <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Margin="0 40 0 0">
                            <Label Content="欢迎使用 iDesk" Style="{DynamicResource LogoLabel}" FontSize="22"/>
                            <Label Content="开始你的对话吧" Style="{DynamicResource DetailLabel}" Margin="0 6 0 0" FontSize="18"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- 输入区域 -->
            <Border Grid.Row="2" Padding="15 10" Background="Transparent"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0 1 0 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InputBox" Height="34" VerticalContentAlignment="Center"
                             Padding="10 0" FontSize="13"
                             Style="{DynamicResource DefaultTextBoxStyle}"
                             AcceptsReturn="True"
                             PreviewKeyDown="OnInputPreviewKeyDown" IsEnabled="true"/>
                    <Button x:Name="MicBtn" Grid.Column="1" Width="32" Height="32" Margin="0 0 6 0"
                            Style="{DynamicResource FadedButtonStyle}" Click="OnMicClick"
                            ToolTip="语音输入">
                        <Path x:Name="MicIcon" Data="{DynamicResource IconMic}" Stretch="Uniform"
                              Fill="{DynamicResource ActionIconBrush}" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="SendBtn" Grid.Column="2" Width="70" Height="34"
                            Style="{DynamicResource DefaultButtonStyle}" Click="OnSendClick">
                        <Label x:Name="SendBtnLabel" Content="发送" FontSize="13"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
