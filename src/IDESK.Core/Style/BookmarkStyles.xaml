    <!-- ── 31～50 · 赛博朋克风格（固定颜色，双层边框 + 异形切割） ── -->

    <!-- 31 · 六边青 -->
    <DataTemplate x:Key="Bookmark_31">
        <Grid x:Name="BookmarkContent" Width="160" Height="26" local:DeskWidget.DragInward="100" local:DeskWidget.DragOutward="4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="0"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
            <Path x:Name="BookmarkTri" Grid.Column="0" Visibility="Collapsed"/>
            <Border x:Name="BookmarkBody" Grid.Column="1" Background="Transparent">
                <Grid>
