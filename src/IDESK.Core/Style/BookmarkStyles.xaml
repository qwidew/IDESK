<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:IDESK.Core">

    <!-- ── 主窗口边框 ── -->

    <Style x:Key="MainBodyStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- ============================================================ -->
    <!-- 书签预设 Bookmark_0 ～ Bookmark_N                              -->
    <!-- 每套必须包含:                                                  -->
    <!--   Grid x:Name="BookmarkContent"                                -->
    <!--     Path x:Name="BookmarkTri"                                  -->
    <!--     Border x:Name="BookmarkBody"                               -->
    <!-- 可选的附加属性（覆盖 CS 默认值）：                               -->
    <!--   local:DeskWidget.DragInward=\"80\"                           -->
    <!--   local:DeskWidget.DragOutward=\"0\"                           -->
    <!-- ============================================================ -->

    <!-- ── 0 · 默认（两侧竖线，经典蓝） ── -->

    <DataTemplate x:Key="Bookmark_0">
        <Grid x:Name="BookmarkContent" Width="150" Height="22" local:DeskWidget.DragInward="120" local:DeskWidget.DragOutward="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <Path x:Name="BookmarkTri" Grid.Column="0" Visibility="Collapsed"/>
            <Border x:Name="BookmarkBody" Grid.Column="1" Background="{DynamicResource Blue5Brush}" CornerRadius="0">
                <Grid>
                    <Rectangle Width="2" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource Blue9Brush}" Margin="4 6 0 6"/>
                    <TextBlock Text="书签" Foreground="{DynamicResource Blue9Brush}" FontSize="14"
                               FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle Width="2" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                               Fill="{DynamicResource Blue9Brush}" Margin="0 6 4 6"/>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- ── 1 · 双旗（两端箭头，左右对称）红 ── -->

    <DataTemplate x:Key="Bookmark_1">
        <Grid x:Name="BookmarkContent" Width="160" Height="22" local:DeskWidget.DragInward="120" local:DeskWidget.DragOutward="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="0"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
            <Path x:Name="BookmarkTri" Grid.Column="0" Visibility="Collapsed"/>
            <Border x:Name="BookmarkBody" Grid.Column="1" Background="Transparent" CornerRadius="0">
                <Grid>
                    <Path Data="M 12,0 L 148,0 L 160,11 L 148,22 L 12,22 L 0,11 Z"
                          Fill="{DynamicResource Red5Brush}" Stretch="Fill"/>
                    <TextBlock Text="书签" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- ── 2 · 胶囊（全圆角）青 ── -->

