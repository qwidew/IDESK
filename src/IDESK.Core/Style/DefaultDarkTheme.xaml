<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         Semantic Brushes — use these in all consumer pages
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Page & Surface ── -->
    <SolidColorBrush x:Key="ThemePageBackground" Color="#282828"/>
    <SolidColorBrush x:Key="SectionBgBrush" Color="{StaticResource DarkGray1}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource DarkGray1}"/>
    <SolidColorBrush x:Key="ItemBgBrush" Color="{StaticResource DarkGray2}"/>
    <SolidColorBrush x:Key="ItemHoverBgBrush" Color="{StaticResource DarkGray4}"/>
    <SolidColorBrush x:Key="ItemPressedBgBrush" Color="{StaticResource DarkGray5}"/>
    <SolidColorBrush x:Key="ItemSelectedBgBrush" Color="{StaticResource DarkGray2}"/>

    <!-- ── Text ── -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource DarkWhite}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource DarkBlue7}"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="{StaticResource DarkWhite}"/>

    <!-- ── Accent ── -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource DarkBlue5}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource DarkBlue4}"/>
    <SolidColorBrush x:Key="AccentMidBrush" Color="{StaticResource DarkBlue3}"/>

    <!-- ── Borders ── -->
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource DarkGray3}"/>
    <SolidColorBrush x:Key="SelectedBorderBrush" Color="{StaticResource DarkGray5}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource DarkGray3}"/>

    <!-- ── Icons ── -->
    <SolidColorBrush x:Key="ActionIconBrush" Color="{StaticResource DarkBlue5}"/>
    <SolidColorBrush x:Key="NavIconBrush" Color="{StaticResource DarkBlue6}"/>
    <SolidColorBrush x:Key="StatusIconBrush" Color="{StaticResource DarkBlue5}"/>

    <!-- ── Danger ── -->
    <SolidColorBrush x:Key="DangerBgBrush" Color="{StaticResource DarkRed5}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DarkRed5}"/>
    <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DarkRed9}"/>
    <SolidColorBrush x:Key="DangerPressedBgBrush" Color="{StaticResource DarkRed6}"/>

    <!-- ── Scrollbar ── -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="{StaticResource DarkGray3}"/>

    <!-- ── Close Button ── -->
    <SolidColorBrush x:Key="CloseButtonHoverBg" Color="#A02314"/>
    <SolidColorBrush x:Key="CloseButtonHoverFg" Color="White"/>

    <!-- ═══════════════════════════════════════════════════════════════
         Control Styles
         ═══════════════════════════════════════════════════════════════ -->

    <!-- 一般按钮：深色背景，浅色前景 -->
    <Style x:Key="DefaultButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ItemBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ItemPressedBgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 危险按钮：深红色调 -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource DangerBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextOnDangerBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerPressedBgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 无边按钮 -->
    <Style x:Key="BorderlessButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ItemHoverBgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ItemPressedBgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 淡按钮 -->
    <Style x:Key="FadedButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="4"
                            RenderTransformOrigin="0.5,0.5">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 默认文本框 -->
    <Style x:Key="DefaultTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#2D2D2D"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="#555"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox 默认样式 -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer Focusable="False" Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBoxItem -->
    <Style TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource ItemHoverBgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBlock -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <!-- PasswordBox -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <!-- Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style TargetType="Label" x:Key="LogoLabel">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style TargetType="Label" x:Key="DetailLabel">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- 无 Chrome 按钮 -->
    <Style x:Key="NoChromeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Calendar -->
    <Style TargetType="Calendar">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- 内联编辑框 -->
    <Style x:Key="InlineEditBoxStyle" TargetType="TextBox">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- 导航栏项 -->
    <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10 10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Indicator" Grid.Column="0"
                                    Width="3" VerticalAlignment="Stretch"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1.5"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed"
                                    Margin="0 3 6 3"/>
                            <ContentPresenter Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ItemHoverBgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            <Setter Property="Background" Value="{DynamicResource ItemSelectedBgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 日历日期单元格 -->
    <Style x:Key="CalendarDayCellStyle" TargetType="Border">
        <Setter Property="Padding" Value="2 4 0 0"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <!-- 滚动条 -->
    <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="MinWidth" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track x:Name="PART_Track" IsDirectionReversed="true">
                        <Track.Thumb>
                            <Thumb BorderThickness="0">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="MinHeight" Value="20"/>
                                        <Setter Property="Background" Value="{DynamicResource ScrollbarThumbBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="3"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         Palette Brushes — backward compat for BookmarkStyles etc.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Red -->
    <SolidColorBrush x:Key="Red2Brush" Color="{StaticResource DarkRed2}"/>
    <SolidColorBrush x:Key="Red5Brush" Color="{StaticResource DarkRed5}"/>

    <!-- Pink -->
    <SolidColorBrush x:Key="Pink5Brush" Color="{StaticResource DarkPink5}"/>
    <SolidColorBrush x:Key="Pink8Brush" Color="{StaticResource DarkPink8}"/>
    <SolidColorBrush x:Key="Pink9Brush" Color="{StaticResource DarkPink9}"/>

    <!-- Purple -->
    <SolidColorBrush x:Key="Purple5Brush" Color="{StaticResource DarkPurple5}"/>
    <SolidColorBrush x:Key="Purple8Brush" Color="{StaticResource DarkPurple8}"/>
    <SolidColorBrush x:Key="Purple9Brush" Color="{StaticResource DarkPurple9}"/>

    <!-- DeepPurple -->
    <SolidColorBrush x:Key="DeepPurple5Brush" Color="{StaticResource DarkDeepPurple5}"/>
    <SolidColorBrush x:Key="DeepPurple8Brush" Color="{StaticResource DarkDeepPurple8}"/>
    <SolidColorBrush x:Key="DeepPurple9Brush" Color="{StaticResource DarkDeepPurple9}"/>

    <!-- Indigo -->
    <SolidColorBrush x:Key="Indigo5Brush" Color="{StaticResource DarkIndigo5}"/>
    <SolidColorBrush x:Key="Indigo8Brush" Color="{StaticResource DarkIndigo8}"/>
    <SolidColorBrush x:Key="Indigo9Brush" Color="{StaticResource DarkIndigo9}"/>

    <!-- Blue -->
    <SolidColorBrush x:Key="Blue0Brush" Color="{StaticResource DarkBlue0}"/>
    <SolidColorBrush x:Key="Blue1Brush" Color="{StaticResource DarkBlue1}"/>
    <SolidColorBrush x:Key="Blue2Brush" Color="{StaticResource DarkBlue2}"/>
    <SolidColorBrush x:Key="Blue5Brush" Color="{StaticResource DarkBlue5}"/>
    <SolidColorBrush x:Key="Blue7Brush" Color="{StaticResource DarkBlue7}"/>
    <SolidColorBrush x:Key="Blue8Brush" Color="{StaticResource DarkBlue8}"/>
    <SolidColorBrush x:Key="Blue9Brush" Color="{StaticResource DarkBlue9}"/>

    <!-- Cyan -->
    <SolidColorBrush x:Key="Cyan5Brush" Color="{StaticResource DarkCyan5}"/>
    <SolidColorBrush x:Key="Cyan8Brush" Color="{StaticResource DarkCyan8}"/>
    <SolidColorBrush x:Key="Cyan9Brush" Color="{StaticResource DarkCyan9}"/>

    <!-- Teal -->
    <SolidColorBrush x:Key="Teal5Brush" Color="{StaticResource DarkTeal5}"/>
    <SolidColorBrush x:Key="Teal8Brush" Color="{StaticResource DarkTeal8}"/>
    <SolidColorBrush x:Key="Teal9Brush" Color="{StaticResource DarkTeal9}"/>

    <!-- Green -->
    <SolidColorBrush x:Key="Green5Brush" Color="{StaticResource DarkGreen5}"/>
    <SolidColorBrush x:Key="Green6Brush" Color="{StaticResource DarkGreen6}"/>
    <SolidColorBrush x:Key="Green8Brush" Color="{StaticResource DarkGreen8}"/>
    <SolidColorBrush x:Key="Green9Brush" Color="{StaticResource DarkGreen9}"/>

    <!-- Orange -->
    <SolidColorBrush x:Key="Orange5Brush" Color="{StaticResource DarkOrange5}"/>
    <SolidColorBrush x:Key="Orange8Brush" Color="{StaticResource DarkOrange8}"/>
    <SolidColorBrush x:Key="Orange9Brush" Color="{StaticResource DarkOrange9}"/>

    <!-- DeepOrange -->
    <SolidColorBrush x:Key="DeepOrange5Brush" Color="{StaticResource DarkDeepOrange5}"/>
    <SolidColorBrush x:Key="DeepOrange8Brush" Color="{StaticResource DarkDeepOrange8}"/>
    <SolidColorBrush x:Key="DeepOrange9Brush" Color="{StaticResource DarkDeepOrange9}"/>

    <!-- Amber -->
    <SolidColorBrush x:Key="Amber5Brush" Color="{StaticResource DarkAmber5}"/>

</ResourceDictionary>
