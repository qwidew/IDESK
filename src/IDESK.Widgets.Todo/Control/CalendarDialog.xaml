<Window x:Class="IDESK.Widgets.Todo.Control.CalendarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="280" Height="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="{DynamicResource CardBackgroundBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Deactivated="OnDeactivated"
        PreviewKeyDown="OnPreviewKeyDown">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- 标题栏（可拖拽） -->
        <Grid Grid.Row="0" Height="36" Background="{DynamicResource SectionBgBrush}"
              MouseDown="OnTitleMouseDown">
            <Label Content="选择日期" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="✕" Width="24" Height="24"
                    HorizontalAlignment="Right" Margin="0 0 6 0"
                    Style="{DynamicResource BorderlessButtonStyle}"
                    Cursor="Hand" Click="OnCloseClick"/>
        </Grid>
        <!-- 日历 -->
        <Calendar x:Name="DatePicker" Grid.Row="1"
                  SelectedDatesChanged="OnSelectedDatesChanged"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Margin="12 8" BorderThickness="0"
                  Background="Transparent"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderBrush="{DynamicResource CardBorderBrush}"/>
        <!-- 底部按钮 -->
        <Grid Grid.Row="2" Height="44"
              Background="{DynamicResource SectionBgBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Content="清除日期" Width="100" Height="28"
                        Style="{DynamicResource BorderlessButtonStyle}"
                        Cursor="Hand" Click="OnClearClick" FontSize="12"
                        Foreground="{DynamicResource DangerBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
