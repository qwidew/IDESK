<UserControl x:Class="IDESK.Widgets.Notes.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0 4 0 8">
            <Label x:Name="TitleText" Content="{Binding Title}" FontSize="16"
                   Padding="0" VerticalAlignment="Center"
                   PreviewMouseLeftButtonDown="OnEditTitle"/>
            <TextBox x:Name="TitleBox" Visibility="Collapsed"
                     Text="{Binding Title, UpdateSourceTrigger=LostFocus}"
                     LostFocus="OnEditTitleEnd" KeyDown="OnEditTitleKeyDown"
                     Style="{DynamicResource InlineEditBoxStyle}"
                     FontSize="16" HorizontalAlignment="Center"/>
        </Grid>

        <TextBox Grid.Row="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" AcceptsTab="True"
                 BorderThickness="0" Background="Transparent"
                 FontSize="13" Padding="5" Margin="0"
                 CaretBrush="{DynamicResource TextPrimaryBrush}"/>
    </Grid>
</UserControl>
