<UserControl x:Class="IDESK.Widgets.Plan.PlanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <!-- 左栏：今日计划 -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 + 日期导航 -->
            <Grid Grid.Row="0" Margin="0 0 0 6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="◀" Width="28" Height="28"
                        Style="{DynamicResource BorderlessButtonStyle}"
                        Command="{Binding PrevDayCommand}" Cursor="Hand"/>
                <TextBlock Grid.Column="1" Text="{Binding DateLabel}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Cursor="Hand" PreviewMouseDown="OnDateClick"/>
                <Button Grid.Column="2" Content="▶" Width="28" Height="28"
                        Style="{DynamicResource BorderlessButtonStyle}"
                        Command="{Binding NextDayCommand}" Cursor="Hand"/>
            </Grid>

            <!-- 计划列表 -->
            <ListBox Grid.Row="2" ItemsSource="{Binding Items}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0" Background="Transparent">
                <ListBox.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="6" Padding="8 6" Margin="0 2"
                                Background="{DynamicResource CardBackgroundBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 完成按钮 -->
                                <Button Grid.Column="0" Width="15" Height="15" Margin="0 0 6 0"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource BorderlessButtonStyle}">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <Path Data="{DynamicResource IconUnchecked}" Stretch="Uniform"
                                                          Fill="{DynamicResource ActionIconBrush}" Width="15" Height="15"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                    <Setter Property="Content">
                                                        <Setter.Value>
                                                            <Grid Width="15" Height="15">
                                                                <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"/>
                                                                <Path Data="{DynamicResource IconCheck}" Stretch="Uniform"
                                                                      Fill="{DynamicResource ActionIconBrush}" Width="15" Height="15"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Path.RenderTransform>
                                                                        <TranslateTransform X="1.8" Y="-0.8"/>
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                            </Grid>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- 时间 -->
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 6 0">
                                    <Run Text="{Binding StartTime}"/>
                                    <Run Text=" - "/>
                                    <Run Text="{Binding EndTime}"/>
                                </TextBlock>
                                <!-- 内容 -->
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13"
                                           Text="{Binding Content}"
                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- 删除 -->
                                <Button Grid.Column="3" Width="15" Height="15" Content="×"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource FadedButtonStyle}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 添加表单 -->
            <Border Grid.Row="3" CornerRadius="6" Padding="8" Margin="0 6 0 0"
                    Background="{DynamicResource SectionBgBrush}">
                <StackPanel>
                    <Grid Margin="0 0 0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewContent, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" FontSize="12" Padding="6 0"
                                 Style="{DynamicResource DefaultTextBoxStyle}"/>
                        <Button Grid.Column="1" Content="添加" Width="50" Height="28" Margin="4 0 0 0"
                                Style="{DynamicResource DefaultButtonStyle}" FontSize="12"
                                Command="{Binding AddCommand}"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="开始" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 4 0"/>
                        <TextBox Grid.Column="1" Text="{Binding NewStartTime}" Height="24" FontSize="11"
                                 Padding="4 0" Style="{DynamicResource DefaultTextBoxStyle}"/>
                        <TextBlock Grid.Column="2" Text="结束" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="4 0 4 0"/>
                        <TextBox Grid.Column="3" Text="{Binding NewEndTime}" Height="24" FontSize="11"
                                 Padding="4 0" Style="{DynamicResource DefaultTextBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 分割线 -->
        <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource SeparatorBrush}"/>

        <!-- 右栏：AI 对话 -->
        <Grid Grid.Column="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="AI 规划助手" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0 0 0 6"/>

            <ScrollViewer Grid.Row="1" x:Name="ChatScroll" Padding="0 0 4 0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="6 6 0 6"
                    BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0 1 0 0"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInput" Height="30" FontSize="12" Padding="6 0"
                             Style="{DynamicResource DefaultTextBoxStyle}"
                             AcceptsReturn="True"
                             PreviewKeyDown="OnChatPreviewKeyDown"/>
                    <Button Grid.Column="1" x:Name="ChatSendBtn" Content="发送" Width="50" Height="30"
                            Margin="6 0 4 0"
                            Style="{DynamicResource DefaultButtonStyle}" FontSize="12"
                            Click="OnChatSendClick"/>
                    <Button Grid.Column="2" x:Name="SettleBtn" Width="30" Height="30" Margin="4 0 0 0"
                            Style="{DynamicResource BorderlessButtonStyle}" Click="OnSettleClick"
                            ToolTip="核算今日">
                        <Path Data="{DynamicResource IconCheck}" Stretch="Uniform"
                              Fill="{DynamicResource DangerBrush}" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
