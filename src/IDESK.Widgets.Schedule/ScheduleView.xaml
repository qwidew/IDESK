<UserControl x:Class="IDESK.Widgets.Schedule.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IDESK.Widgets.Schedule">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:MonthlyCalendar x:Name="Calendar" Grid.Column="0" Margin="5"/>

        <Grid Grid.Column="1" Margin="10 5 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label x:Name="DateLabel" Grid.Row="0" Content="选择日期" FontSize="14" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0 0 0 8"/>

            <ListBox Grid.Row="1" x:Name="ItemList" BorderThickness="0" Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="4" Background="{DynamicResource ItemBgBrush}" Padding="6 4" Margin="0 2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="{Binding Time}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Padding="0" VerticalAlignment="Center"
                                       Margin="0 0 6 0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Content}" FontSize="13"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <Button Grid.Column="2" Width="16" Height="16" Style="{DynamicResource FadedButtonStyle}"
                                        VerticalAlignment="Center" Margin="4 0 0 0" Click="OnDeleteItem"
                                        Tag="{Binding Id}">
                                    <Path Data="{DynamicResource IconDelete}" Stretch="Uniform"
                                          Fill="{DynamicResource ActionIconBrush}" Width="10" Height="10"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2" Margin="0 8 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="🕐" FontSize="14" VerticalAlignment="Center" Padding="0 4 0 0"/>
                <TextBox x:Name="TimeBox" Grid.Column="1" Width="50" Style="{DynamicResource DefaultTextBoxStyle}"
                         Height="26" FontSize="12" Margin="0 0 4 0"/>
                <TextBox x:Name="ContentBox" Grid.Column="2" Style="{DynamicResource DefaultTextBoxStyle}"
                         Height="26" FontSize="12"/>
                <Button Grid.Column="3" Width="30" Height="26" Margin="4 0 0 0"
                        Style="{DynamicResource DefaultButtonStyle}" Click="OnAddClick">
                    <Path Data="{DynamicResource IconAdd}" Stretch="Uniform"
                          Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14"/>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
