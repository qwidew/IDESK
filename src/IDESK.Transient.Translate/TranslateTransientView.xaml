<UserControl x:Class="IDESK.Transient.Translate.TranslateTransientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:IDESK.Core;assembly=IDESK.Core">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 输入卡片（单行+↵按钮，Shift+Enter换行 Enter发送） -->
        <Border CornerRadius="8" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                Padding="8 4">
            <DockPanel>
                <Button Content="发送" Width="40" Height="28" DockPanel.Dock="Right"
                        Style="{DynamicResource FadedButtonStyle}"
                        Command="{Binding TranslateCommand}" Cursor="Hand"
                        FontSize="12"/>
                <Button x:Name="MicBtn" Width="26" Height="26" DockPanel.Dock="Right"
                        Style="{DynamicResource FadedButtonStyle}" Click="OnMicClick"
                        ToolTip="语音输入" Margin="0 0 4 0">
                    <Path x:Name="MicIcon" Data="{DynamicResource IconMic}" Stretch="Uniform"
                          Fill="{DynamicResource ActionIconBrush}" Width="14" Height="14"/>
                </Button>
                <Button Content="{Binding DirectionText}" Width="52" Height="22"
                        DockPanel.Dock="Left" Cursor="Hand" FontSize="11"
                        Style="{DynamicResource FadedButtonStyle}"
                        Command="{Binding ToggleDirectionCommand}"
                        Margin="0,0,6,0"/>
                <TextBox x:Name="InputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" FontSize="14"
                         BorderThickness="0" Background="Transparent"
                         VerticalContentAlignment="Center"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         PreviewKeyDown="OnInputPreviewKeyDown"/>
            </DockPanel>
        </Border>

        <!-- 结果卡片 -->
        <Border x:Name="ResultCard" Grid.Row="1" Margin="0,12,0,0" CornerRadius="8"
                Background="{DynamicResource CardBackgroundBrush}" Padding="14"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <ItemsControl ItemsSource="{Binding DisplayItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Text}"
                                     IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" IsTabStop="False" Padding="0"
                                     FontSize="{Binding FontSize}"
                                     FontWeight="{Binding Weight}"
                                     core:ThemeHelper.ForegroundKey="{Binding ForegroundKey}"
                                     Margin="{Binding Margin}"
                                     TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
